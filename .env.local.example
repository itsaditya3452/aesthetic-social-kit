# Copy this file to .env.local for local development, and add the same
# variables in your Vercel project's Settings → Environment Variables for
# production. Neither variable is required — the app works without them
# using the default key baked into lib/indexNowConfig.js — but setting your
# own is recommended once you're live.

# The IndexNow verification key. 8-128 chars, letters/digits/hyphens only.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
INDEXNOW_KEY=

# Optional shared secret that gates POST /api/indexnow. If set, requests must
# include a matching `x-indexnow-secret` header. Leave blank while testing
# locally; set a real value before deploying so random visitors can't trigger
# submissions on your behalf.
INDEXNOW_SUBMIT_SECRET=

# Required only for the Link in Bio Builder (/bio-link-builder + /bio/[username]).
# Every other tool works with these left blank. Get these from your Supabase
# project's Settings → API page. NEXT_PUBLIC_ vars are exposed to the browser
# on purpose — this is the "publishable"/anon key, meant to be public; row-level
# security (set up by supabase/schema.sql) is what actually protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
